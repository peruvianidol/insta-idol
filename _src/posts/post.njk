---
layout: base.njk
hideViewToggle: true
pagination:
  data: posts
  size: 1
  alias: post
permalink: "/posts/{{ post | postSlug }}/"
eleventyComputed:
  title: "{{ post.title if post.title else 'Post' }} | Insta-Idol"
---

<article class="post flow">
  <div class="post-media">
    {%- for url in post.media -%}
      {%- if url.slice(-3) === "mp4" -%}
        <video src="{{ url | optimize('/w_1200,q_auto,f_auto') }}" controls loop playsinline preload="none"></video>
      {%- else -%}
        <img src="{{ url | optimize('/w_1200,q_auto,f_auto') }}" alt="{{ post.alt or post.title }}" eleventy:ignore{% if loop.first %} fetchpriority="high"{% else %} loading="lazy"{% endif %}>
      {%- endif -%}
    {%- endfor -%}
  </div>
  <div class="post-caption">
    {%- if post.title -%}
      <p><strong>peruviandiol</strong> {{ post.title }}</p>
    {%- endif -%}
    <time datetime="{{ post.creation_timestamp }}">{{ post.creation_timestamp | postDate }}</time>
  </div>
</article>

<nav class="pagination">
  <ol>
    <li>{% if pagination.href.previous %}<a href="{{ pagination.href.previous }}">Newer</a>{% endif %}</li>
    <li><a href="/">All posts</a></li>
    <li>{% if pagination.href.next %}<a href="{{ pagination.href.next }}">Older</a>{% endif %}</li>
  </ol>
</nav>
